# --- Core / Node ---
# development | production | test
NODE_ENV=

# --- Backend server (backend/src/index.js) ---
# HTTP port when running the Express app locally (default 3001)
PORT=

# --- CORS & deployment URLs (backend/src/config/expressApp.js; also Vercel injects VERCEL_*) ---
# Comma-separated browser origins allowed in addition to localhost defaults
ALLOWED_ORIGINS=
# Vercel preview hostname only (no scheme), e.g. my-app-git-main-team.vercel.app
VERCEL_URL=
# Vercel production hostname only (no scheme)
VERCEL_PROJECT_PRODUCTION_URL=
# Public site URL (with scheme); used for CORS and frontend URL resolution
VITE_PUBLIC_SITE_URL=

# --- PostgreSQL (backend/src/database/pg.js, api/_shared/db.js) ---
# Postgres connection string (e.g. RDS)
DATABASE_URL=

# --- Amazon Cognito — server JWT verification (backend/src/middleware/auth.js, api/_shared/auth.js) ---
# User pool ID, e.g. us-east-1_xxxx
COGNITO_USER_POOL_ID=
# App client ID; optional for verify but required for audience check when set
COGNITO_CLIENT_ID=
# Not read by backend auth: JWKS region is inferred from the prefix of COGNITO_USER_POOL_ID (e.g. us-east-1)

# --- Amazon Cognito — browser (app/src/lib/cognitoAuth.ts) ---
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# --- API base (app/src/lib/urlConfig.ts) ---
# Override backend API origin when the SPA is not served from the same host
VITE_BACKEND_URL=

# --- OpenAI (backend AI routes, api/chat.js, api/generate-workout.js) ---
OPENAI_API_KEY=
# Model id override (defaults vary by route)
OPENAI_MODEL=

# --- Cal AI (backend/src/integrations/calai.js, personalization engines) ---
CALAI_API_KEY=

# --- Fitbit OAuth (backend/src/routes/input.js, api/fitbit/*) ---
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=
# Exposed to the browser for OAuth start (app/src/lib/fitbitAuth.ts)
VITE_FITBIT_CLIENT_ID=
VITE_FITBIT_REDIRECT_URI=

# --- Oura OAuth (api/oura/*) ---
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=
VITE_OURA_CLIENT_ID=
VITE_OURA_REDIRECT_URI=

# --- OAuth state signing (api/fitbit/start.js, api/oura/start.js, callbacks) ---
OAUTH_STATE_SECRET=
# Set to "true" to accept legacy unsigned state (migration only)
ALLOW_LEGACY_OAUTH_STATE=

# --- ML / feature flags (backend/src/routes/ml.js) ---
HF_ENABLE_REPLAY_PROMOTIONS=
HF_ENABLE_STRICT_PROMOTION_GATES=

# --- Vercel serverless entry (backend/src/index.js) ---
# Set by Vercel when the app runs as a serverless function
VERCEL=

# --- Frontend dev / tooling (optional) ---
VITE_ALLOW_UNVALIDATED_WORKOUT_SAVE=
VITE_ENABLE_WORKOUT_CLEANUP=
VISUAL_BASE_URL=
